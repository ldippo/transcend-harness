{
  "event": "PreToolUse",
  "entry": {
    "matcher": "Bash",
    "hooks": [
      {
        "type": "command",
        "if": "Bash(git push *)",
        "command": "{script_ref}/blocking/push-gate.sh",
        "args": ["lint/typecheck", "{lint_cmd} && {typecheck_cmd}"],
        "timeout": 600,
        "statusMessage": "Running lint + typecheck before push…"
      }
    ]
  }
}
